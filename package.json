{
  "name": "pharmaqms",
  "private": true,
  "version": "1.0.0",
  "description": "Enterprise Pharmaceutical Quality Management System",
  "author": "Dr. Daoud Tajeldeinn",
  "main": "main.cjs",
  "scripts": {
    "dev": "cd app && npm run dev",
    "build": "cd app && npm run build",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.pharmaqms.enterprise",
    "productName": "PharmaQMS Enterprise",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist-electron",
      "app": "app",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/@electron/**/*",
      "!**/*.map",
      "!src/**/*",
      "!scripts/**/*",
      "!materials/**/*",
      "!*.log",
      "!*.md",
      "!.gitignore",
      "!.vercel"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icons/icon-512x512.png"
    },
    "portable": {
      "artifactName": "PharmaQMS-Enterprise-1.0.0.exe"
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "electron": "41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "wait-on": "^9.0.4"
  }
}
